{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "functions": {
    "api/ssr.js": {
      "runtime": "nodejs20.x",
      "includeFiles": "dist/ng-ecommerce/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/ssr.js"
    }
  ]
}